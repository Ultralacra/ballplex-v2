---
import { siteConfig } from "../data/site";
---

<section
  class="relative flex min-h-screen items-center justify-center overflow-hidden"
>
  <div class="absolute inset-0 z-0">
    <video
      class="absolute inset-0 h-full w-full object-cover"
      src="/ballplex-promo.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/55 to-brand-black"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-30"></div>
  </div>

  <div class="container-page relative z-10 flex flex-col items-center py-32 text-center">
    <p
      class="mb-6 text-sm font-semibold uppercase tracking-[0.35em] text-brand-teal"
      data-reveal
    >
      Viera, Florida
    </p>
    <h1
      class="max-w-6xl text-5xl font-extrabold leading-none tracking-tight text-white md:text-7xl lg:text-8xl"
      data-reveal
      data-delay="100"
    >
      {siteConfig.tagline.replace(/\.\s*$/, "").split(". ").map((line, i) => (
        <>
          {line}.{i < 2 && <br />}
        </>
      ))}
    </h1>
    <p
      class="mt-8 max-w-2xl text-lg leading-relaxed text-white/50 md:text-xl"
      data-reveal
      data-delay="200"
    >
      {siteConfig.description}
    </p>
    <div
      class="mt-12 flex flex-col gap-4 sm:flex-row"
      data-reveal
      data-delay="300"
    >
      <a
        href={siteConfig.bookNowUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-base px-10 py-5"
      >
        <span>Get Started</span>
      </a>
      <a href="/programs" class="btn-outline-light text-base px-10 py-5">
        Explore Programs
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 z-10 -translate-x-1/2 animate-bounce">
    <svg class="h-6 w-6 text-white/30" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>
