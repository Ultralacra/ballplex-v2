---
import { facilityFeatures } from "../data/site";
---

<section class="relative overflow-hidden bg-zinc-950 py-20 md:py-28">
  <div class="absolute inset-0 bg-grid-pattern"></div>

  <div class="container-page relative z-10">
    <div class="mb-16 text-center" data-reveal>
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-teal">
        Our Facility
      </p>
      <h2 class="section-heading mt-4 text-white">
        Why Athletes Choose Ballplex
      </h2>
      <p class="section-subtitle mx-auto text-zinc-400">
        Everything a serious baseball or softball athlete needs to improve their game, all in one place.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        facilityFeatures.map((feature, i) => (
          <div
            class="glow-on-hover glass-card group p-8 transition-all duration-500 hover:bg-white/10 hover:border-white/20"
            data-reveal
            data-delay={String(i * 80)}
          >
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-teal/20 text-brand-teal transition-transform duration-500 group-hover:scale-110 group-hover:bg-brand-teal group-hover:text-brand-black">
              <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white transition-colors duration-300 group-hover:text-brand-teal">
              {feature.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="mt-16 grid gap-4 overflow-hidden rounded-3xl sm:grid-cols-2" data-reveal data-delay="400">
      <div class="img-zoom">
        <img
          src="https://theballplex.com/wp-content/uploads/brizy/imgs/IMG_4117-548x731x0x80x548x570x1758559312.webp"
          alt="Ballplex Facility"
          class="h-64 w-full object-cover sm:h-96"
          loading="lazy"
        />
      </div>
      <div class="img-zoom">
        <img
          src="https://theballplex.com/wp-content/uploads/brizy/imgs/IMG_4121-323x431x0x86x323x259x1758559372.webp"
          alt="Ballplex Training Area"
          class="h-64 w-full object-cover sm:h-96"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
