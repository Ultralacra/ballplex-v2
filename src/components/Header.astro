---
import { navLinks, siteConfig } from "../data/site";
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 border-b border-transparent bg-transparent transition-all duration-500"
>
  <nav id="site-nav" class="container-page flex h-24 items-center justify-between transition-all duration-500 md:h-32">
    <a href="/" class="flex items-center gap-3" aria-label="Ballplex Home">
      <img
        src="/LOGO.png"
        alt="Ballplex"
        class="h-20 w-auto transition-all duration-500 md:h-28"
        id="header-logo"
      />
    </a>

    <ul class="hidden items-center gap-1 lg:flex">
      {
        navLinks.map((link) => (
          <li class={link.children ? "group relative" : ""}>
            <a
              href={link.href}
              class="link-underline rounded-lg px-4 py-2 text-sm font-medium text-white/60 transition-colors hover:text-white"
            >
              {link.label}
              {link.children && (
                <svg class="ml-1 inline-block h-3 w-3 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              )}
            </a>
            {link.children && (
              <div class="invisible absolute top-full left-0 z-50 mt-1 min-w-[200px] translate-y-2 rounded-xl border border-white/10 bg-zinc-950/95 p-2 opacity-0 shadow-2xl backdrop-blur-xl transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class="block rounded-lg px-4 py-2.5 text-sm text-white/60 transition-colors hover:bg-white/5 hover:text-white"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-4">
      <a
        href={siteConfig.bookNowUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary hidden lg:inline-flex"
      >
        <span>Book Now</span>
      </a>

      <a
        href={siteConfig.bookNowUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center rounded-lg p-2 transition-colors hover:bg-white/10 lg:hidden"
        aria-label="Book Now"
        style="background: linear-gradient(135deg, #86C9B6, #5fa899);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#09090b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
      </a>

      <button
        id="mobile-menu-btn"
        class="flex flex-col gap-1.5 p-2 lg:hidden"
        aria-label="Toggle menu"
      >
        <span class="block h-0.5 w-5 bg-white transition-all duration-300"></span>
        <span class="block h-0.5 w-5 bg-white transition-all duration-300"></span>
        <span class="block h-0.5 w-5 bg-white transition-all duration-300"></span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-white/10 bg-black/95 backdrop-blur-xl lg:hidden"
  >
    <ul class="container-page flex flex-col gap-1 py-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block rounded-lg px-4 py-3 text-base font-medium text-white/60 transition-colors hover:text-white hover:bg-white/5"
          >
            {link.label}
          </a>
          {link.children && (
            <ul class="ml-4 mt-1 space-y-1 border-l border-white/10 pl-4">
              {link.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="block rounded-lg px-4 py-2 text-sm font-medium text-white/40 transition-colors hover:text-white hover:bg-white/5"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
  }

  const header = document.getElementById("site-header");
  const nav = document.getElementById("site-nav");
  const logo = document.getElementById("header-logo");
  if (header && nav && logo) {
    const scrolledClasses = {
      header: ["bg-black/80", "backdrop-blur-xl", "border-white/10", "shadow-lg"],
      nav: {
        add: ["h-20", "md:h-24"],
        remove: ["h-24", "md:h-32"],
      },
      logo: {
        add: ["h-16", "md:h-24"],
        remove: ["h-20", "md:h-28"],
      },
    };

    window.addEventListener("scroll", () => {
      if (window.scrollY > 20) {
        header.classList.add(...scrolledClasses.header);
        nav.classList.add(...scrolledClasses.nav.add);
        nav.classList.remove(...scrolledClasses.nav.remove);
        logo.classList.add(...scrolledClasses.logo.add);
        logo.classList.remove(...scrolledClasses.logo.remove);
      } else {
        header.classList.remove(...scrolledClasses.header);
        nav.classList.remove(...scrolledClasses.nav.add);
        nav.classList.add(...scrolledClasses.nav.remove);
        logo.classList.remove(...scrolledClasses.logo.add);
        logo.classList.add(...scrolledClasses.logo.remove);
      }
    }, { passive: true });
  }
</script>
