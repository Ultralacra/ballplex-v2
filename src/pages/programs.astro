---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTABanner from "../components/CTABanner.astro";
import CoachCard from "../components/CoachCard.astro";
import { coaches } from "../data/coaches";
import { siteConfig } from "../data/site";
---

<BaseLayout title="Services — Ballplex" description="Explore all Ballplex services: Private Lessons, Memberships, Strength & Conditioning, Cage Rentals, and more.">
  <section class="pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="container-page">
      <div class="text-center" data-reveal>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-teal">
          Services
        </p>
        <h1 class="section-heading">
          Built for Athletes Development
        </h1>
        <p class="section-subtitle mx-auto">
          Technology to Track Your Progress, two Facilities and an Elite Coaching Team.
        </p>
      </div>
    </div>
  </section>

  <section id="lessons" class="bg-brand-dark py-20 md:py-28">
    <div class="container-page">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-teal">
            Private Lessons
          </p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-white md:text-4xl">
            1-on-1 & Duo Instruction
          </h2>
          <p class="mt-4 text-brand-gray leading-relaxed">
            Whether your goal is to make the team, earn a starting spot, or get recruited by top college programs,
            our coaches are here to help you get there. HitTrax and Rapsodo technology are available for detailed
            performance tracking.
          </p>

          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-4">
              <h4 class="font-semibold text-white">Hitting</h4>
              <p class="mt-1 text-sm text-brand-gray">Swing mechanics, approach, Rapsodo data</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-4">
              <h4 class="font-semibold text-white">Pitching</h4>
              <p class="mt-1 text-sm text-brand-gray">Mechanics, velocity, arm care, pitch design</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-4">
              <h4 class="font-semibold text-white">Catching</h4>
              <p class="mt-1 text-sm text-brand-gray">Receiving, blocking, throwing, game IQ</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-4">
              <h4 class="font-semibold text-white">Fielding</h4>
              <p class="mt-1 text-sm text-brand-gray">Footwork, glove work, arm strength</p>
            </div>
          </div>

          <div class="mt-8 overflow-hidden rounded-xl border border-white/5">
            <table class="w-full text-left text-sm">
              <thead class="bg-white/5">
                <tr>
                  <th class="px-6 py-3 font-semibold text-white">Type</th>
                  <th class="px-6 py-3 font-semibold text-white">1H Private</th>
                  <th class="px-6 py-3 font-semibold text-white">1H Duo</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <tr>
                  <td class="px-6 py-3 text-white/60">Hitting / Fielding / Catching</td>
                  <td class="px-6 py-3 font-medium text-white">$80</td>
                  <td class="px-6 py-3 font-medium text-white">$100</td>
                </tr>
                <tr>
                  <td class="px-6 py-3 text-white/60">Softball Pitching</td>
                  <td class="px-6 py-3 font-medium text-white">$80</td>
                  <td class="px-6 py-3 font-medium text-white">$100</td>
                </tr>
                <tr>
                  <td class="px-6 py-3 text-white/60">Baseball Pitching</td>
                  <td class="px-6 py-3 font-medium text-white">$80</td>
                  <td class="px-6 py-3 font-medium text-white">$100</td>
                </tr>
              </tbody>
            </table>
          </div>

          <a
            href={siteConfig.bookNowUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary mt-8 inline-flex"
          >
            <span>Book a Lesson</span>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <img src="https://theballplex.com/wp-content/uploads/brizy/imgs/IMG_4115-433x577x49x0x352x577x1758559248.webp" alt="Training" class="rounded-2xl object-cover h-64 w-full" loading="lazy" />
          <img src="https://theballplex.com/wp-content/uploads/brizy/imgs/IMG_4121-323x431x0x86x323x259x1758559372.webp" alt="Training" class="rounded-2xl object-cover h-64 w-full" loading="lazy" />
          <img src="https://theballplex.com/wp-content/uploads/brizy/imgs/IMG_4126-323x431x0x86x323x259x1758560649.webp" alt="Training" class="rounded-2xl object-cover h-64 w-full" loading="lazy" />
          <img src="https://theballplex.com/wp-content/uploads/brizy/imgs/IMG_4132-355x267x82x0x273x267x1758560807.webp" alt="Training" class="rounded-2xl object-cover h-64 w-full" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="memberships" class="relative overflow-hidden py-20 md:py-28 section-highlight">
    <div class="absolute inset-0 bg-grid-pattern"></div>

    <div class="container-page relative z-10">
      <div class="mb-16 text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-teal">
          Memberships
        </p>
        <h2 class="section-heading">
          Three Tiers. One Goal.
        </h2>
        <p class="section-subtitle mx-auto">
          Plans designed for athletes who take their development seriously. Each plan adds real value with assessments, programming, and exclusive benefits.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-white/5 bg-white/[0.03] p-8 card-hover">
          <p class="text-sm font-semibold uppercase tracking-wider text-brand-teal">Pro</p>
          <p class="mt-2 text-4xl font-bold text-white">$95<span class="text-lg text-brand-gray">/mo</span></p>
          <ul class="mt-6 space-y-3 text-sm text-white/60">
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Assessment Sessions
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              App Access + Programming
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              10% Off Store & Events
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              S&C from $240/mo
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Lessons: $75 single / $45 duo
            </li>
          </ul>
          <a href={siteConfig.bookNowUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-8 w-full">
            <span>Join Pro</span>
          </a>
        </div>

        <div class="rounded-2xl border border-brand-teal/20 bg-white/[0.05] p-8 relative card-hover shadow-lg shadow-brand-teal/5">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-teal px-4 py-1 text-xs font-semibold uppercase text-white">Popular</span>
          <p class="text-sm font-semibold uppercase tracking-wider text-brand-teal">All-Access</p>
          <p class="mt-2 text-4xl font-bold text-white">$175<span class="text-lg text-brand-gray">/mo</span></p>
          <ul class="mt-6 space-y-3 text-sm text-white/60">
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Unlimited Open Cage (+1 Guest)
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              1 Monthly HitTrax Rental
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Open Gym (16+)
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              15% Off Store & Events
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              S&C from $240/mo
            </li>
          </ul>
          <a href={siteConfig.bookNowUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-8 w-full">
            <span>Join All-Access</span>
          </a>
        </div>

        <div class="rounded-2xl border border-white/5 bg-white/[0.03] p-8 card-hover">
          <p class="text-sm font-semibold uppercase tracking-wider text-brand-teal">Elite</p>
          <p class="mt-2 text-4xl font-bold text-white">$295<span class="text-lg text-brand-gray">/mo</span></p>
          <ul class="mt-6 space-y-3 text-sm text-white/60">
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Assessment + Programming
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Unlimited Open Cage (+1 Guest)
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Open Gym (16+)
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              20% Off Store & Events
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              S&C from $200/mo
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Lessons: $65 single / $40 duo
            </li>
          </ul>
          <a href={siteConfig.bookNowUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-8 w-full">
            <span>Join Elite</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="strength" class="bg-brand-dark py-20 md:py-28">
    <div class="container-page">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <img
            src="https://theballplex.com/wp-content/uploads/brizy/imgs/Screenshot-2025-12-02-at-5.13.31-PM-473x588x0x126x473x441x1764713650.png"
            alt="Strength & Conditioning"
            class="rounded-3xl object-cover w-full"
            loading="lazy"
          />
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-teal">
            Strength & Conditioning
          </p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-white md:text-4xl">
            Stronger. Faster. Unstoppable.
          </h2>
          <p class="mt-4 text-brand-gray leading-relaxed">
            Sport-specific training for baseball and softball athletes. Fewer injuries. More power.
            Led by Coach Gianmarco Marcelletti, a former college player with ISSA certifications
            and over 5 years of experience training athletes up to the MLB level.
          </p>

          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-4 text-center">
              <p class="text-2xl font-bold text-white">3:30-5:30PM</p>
              <p class="mt-1 text-xs text-brand-gray">Ages 7-10</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-4 text-center">
              <p class="text-2xl font-bold text-white">5:30-7:30PM</p>
              <p class="mt-1 text-xs text-brand-gray">Ages 11-14</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-4 text-center">
              <p class="text-2xl font-bold text-white">7:30-9:30PM</p>
              <p class="mt-1 text-xs text-brand-gray">High School</p>
            </div>
          </div>

          <div class="mt-8 overflow-hidden rounded-xl border border-white/5">
            <table class="w-full text-left text-sm">
              <thead class="bg-white/5">
                <tr>
                  <th class="px-4 py-3 font-semibold text-white">Sessions</th>
                  <th class="px-4 py-3 font-semibold text-white">Members</th>
                  <th class="px-4 py-3 font-semibold text-white">Non-Members</th>
                  <th class="px-4 py-3 font-semibold text-white">Drop-In</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <tr>
                  <td class="px-4 py-3 text-white/60">2 Days/Week</td>
                  <td class="px-4 py-3 text-white">$240</td>
                  <td class="px-4 py-3 text-white">$280</td>
                  <td class="px-4 py-3 text-brand-teal">$50</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 text-white/60">3 Days/Week</td>
                  <td class="px-4 py-3 text-white">$315</td>
                  <td class="px-4 py-3 text-white">$375</td>
                  <td class="px-4 py-3 text-brand-teal">$50</td>
                </tr>
                <tr>
                  <td class="px-4 py-3 text-white/60">4 Days/Week</td>
                  <td class="px-4 py-3 text-white">$375</td>
                  <td class="px-4 py-3 text-white">$435</td>
                  <td class="px-4 py-3 text-brand-teal">$50</td>
                </tr>
              </tbody>
            </table>
          </div>

          <a href={siteConfig.bookNowUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-8 inline-flex">
            <span>Book S&C</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="rentals" class="relative overflow-hidden py-20 md:py-28 section-highlight">
    <div class="absolute inset-0 bg-grid-pattern"></div>

    <div class="container-page relative z-10">
      <div class="mb-16 text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-teal">
          Cage Rentals
        </p>
        <h2 class="section-heading">
          5 Indoor Cages. Unlimited Possibilities.
        </h2>
        <p class="section-subtitle mx-auto">
          6,000 sqft of indoor cage space with 5 cages available for individual, duo or team rentals. Pitching machines and equipment options available.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <div class="overflow-hidden rounded-xl border border-white/5">
          <table class="w-full text-left text-sm">
            <thead class="bg-white/5">
              <tr>
                <th class="px-6 py-3 font-semibold text-white">What's In</th>
                <th class="px-6 py-3 font-semibold text-white">1 Lane 45ft</th>
                <th class="px-6 py-3 font-semibold text-white">2 Lanes 45ft</th>
                <th class="px-6 py-3 font-semibold text-white">1 Lane 70ft</th>
                <th class="px-6 py-3 font-semibold text-white">2 Lanes 70ft</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <tr>
                <td class="px-6 py-3 text-white/60">Just the Cage</td>
                <td class="px-6 py-3 text-white">$40</td>
                <td class="px-6 py-3 text-white">$75</td>
                <td class="px-6 py-3 text-white">$55</td>
                <td class="px-6 py-3 text-white">$95</td>
              </tr>
              <tr>
                <td class="px-6 py-3 text-white/60">Cage + Equipment</td>
                <td class="px-6 py-3 text-white">$45</td>
                <td class="px-6 py-3 text-white">$80</td>
                <td class="px-6 py-3 text-white">$60</td>
                <td class="px-6 py-3 text-white">$100</td>
              </tr>
              <tr>
                <td class="px-6 py-3 text-white/60">Cage + Machine + Equipment</td>
                <td class="px-6 py-3 text-white">$50</td>
                <td class="px-6 py-3 text-white">$85</td>
                <td class="px-6 py-3 text-white">$65</td>
                <td class="px-6 py-3 text-white">$105</td>
              </tr>
            </tbody>
          </table>
          <p class="px-6 py-3 text-xs text-brand-gray">
            Rates for 1-hour rental. Special discounts for multiple hours and long-term rentals.
          </p>
        </div>

        <div class="rounded-2xl border border-white/5 bg-white/[0.03] p-8">
          <h3 class="text-lg font-semibold text-white">Team Rental Packs</h3>
          <div class="mt-6 space-y-4">
            <div class="flex items-center justify-between rounded-xl border border-white/5 p-4 hover:border-brand-teal/30 transition-all">
              <div>
                <p class="font-semibold text-white">Mint Pack</p>
                <p class="text-xs text-brand-gray">2 Cages · 4 Hours/Month · Machine Included</p>
              </div>
              <p class="text-xl font-bold text-brand-teal">$275</p>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-white/5 p-4 hover:border-brand-teal/30 transition-all">
              <div>
                <p class="font-semibold text-white">Gold Pack</p>
                <p class="text-xs text-brand-gray">2 Cages · 8 Hours/Month · Machine Included</p>
              </div>
              <p class="text-xl font-bold text-brand-teal">$475</p>
            </div>
          </div>
          <a href={siteConfig.bookNowUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-6 w-full">
            <span>Book Now</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="coaches" class="bg-brand-black py-20 md:py-28">
    <div class="container-page">
      <div class="mb-16 text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-teal">
          Coaching Staff
        </p>
        <h2 class="section-heading">
          Meet the Team
        </h2>
        <p class="section-subtitle mx-auto">
          Former professional players with Division 1 experience and years coaching young athletes.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {coaches.map((coach) => <CoachCard coach={coach} />)}
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
