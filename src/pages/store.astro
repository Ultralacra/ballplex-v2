---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Store — Ballplex" description="Ballplex store — coming soon.">
  <section class="flex min-h-[70vh] items-center justify-center pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="container-page text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-teal">
        Store
      </p>
      <h1 class="section-heading">
        Coming Soon
      </h1>
      <p class="section-subtitle mx-auto">
        Our online store is currently under construction. For now, visit us in person or contact us for merchandise inquiries.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="btn-primary"><span>Contact Us</span></a>
        <a href="/programs" class="btn-outline">View Programs</a>
      </div>
    </div>
  </section>
</BaseLayout>
